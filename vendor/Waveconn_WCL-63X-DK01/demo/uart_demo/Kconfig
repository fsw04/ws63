choice
    prompt "Sample"

config UART_POLL
    bool
    prompt "Support UART POLL Sample."
    default n
    depends on ENABLE_UART_SAMPLE
    help
        This option means support UART_POLL Sample.


config UART_INT
    bool
    prompt "Support UART INT Sample."
    default n
    depends on ENABLE_UART_SAMPLE
    help
        This option means support UART_INT Sample.

endchoice